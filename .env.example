# ─────────────────────────────────────────────────────
#  surveychat environment configuration
#
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your key below
#  3. Never commit .env to git (it is already in .gitignore)
# ─────────────────────────────────────────────────────

# Your OpenAI-compatible API key.
# Get this from your API provider, for example OpenAI
# (https://platform.openai.com/api-keys) or OpenRouter
# (https://openrouter.ai/keys). If your institution runs its own LLM proxy,
# use the key and base URL it gives you (set the base URL in app.py).
OPENAI_API_KEY=your-api-key-here
